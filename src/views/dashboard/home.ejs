<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="main">
    <header class="page-header">
      <div>
        <h1>📊 Dashboard</h1>
        <p class="muted">Olá <%= user.name || user.username %>, bem-vindo ao <%= bot.name %></p>
      </div>
      <div class="bot-status" id="botStatusBadge">
        <span class="status-dot status-<%= stats.botStatus %>"></span>
        <span id="botStatusText"><%= stats.botStatus %></span>
      </div>
    </header>

    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">🤖</div>
        <div class="stat-info">
          <div class="stat-label">Status do Bot</div>
          <div class="stat-value" id="statBotStatus"><%= stats.botStatus %></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-info">
          <div class="stat-label">Usuários</div>
          <div class="stat-value"><%= stats.totalUsers %></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">⭐</div>
        <div class="stat-info">
          <div class="stat-label">Premium</div>
          <div class="stat-value"><%= stats.premiumUsers %></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">⚡</div>
        <div class="stat-info">
          <div class="stat-label">Comandos</div>
          <div class="stat-value"><%= stats.totalCommands %></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🖼️</div>
        <div class="stat-info">
          <div class="stat-label">Mídias</div>
          <div class="stat-value"><%= stats.totalMedia %></div>
        </div>
      </div>
    </section>

    <section class="card">
      <h2>🚀 Início Rápido</h2>
      <div class="quick-grid">
        <% if (user.role === 'owner') { %>
          <a href="/dashboard/connect" class="quick-card">
            <div class="quick-icon">🔌</div>
            <div>
              <strong>Conectar Bot</strong>
              <p>QR Code ou Pair Code</p>
            </div>
          </a>
          <a href="/dashboard/commands" class="quick-card">
            <div class="quick-icon">⚡</div>
            <div>
              <strong>Gerenciar Comandos</strong>
              <p>Criar, editar, deletar</p>
            </div>
          </a>
          <a href="/dashboard/media" class="quick-card">
            <div class="quick-icon">🖼️</div>
            <div>
              <strong>Mídias</strong>
              <p>Upload de fotos, vídeos e GIFs</p>
            </div>
          </a>
          <a href="/dashboard/users" class="quick-card">
            <div class="quick-icon">👥</div>
            <div>
              <strong>Usuários</strong>
              <p>Gerenciar contas Free/Premium</p>
            </div>
          </a>
        <% } else { %>
          <div class="quick-card">
            <div class="quick-icon">📞</div>
            <div>
              <strong>Bot WhatsApp</strong>
              <p>+<%= bot.number %></p>
            </div>
          </div>
          <div class="quick-card">
            <div class="quick-icon">👑</div>
            <div>
              <strong>Dono</strong>
              <p><%= owner.name %> · +<%= owner.number %></p>
            </div>
          </div>
        <% } %>
      </div>
    </section>
  </main>
</div>
<%- include('../partials/footer') %>
